# ============================================
# INBOXPILOT — ENVIRONMENT VARIABLES
# Copy this to .env.local and fill in values
# ============================================

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Instagram / Meta ──
# Get these from developers.facebook.com → Your App → Settings
INSTAGRAM_APP_ID=your_app_id
INSTAGRAM_APP_SECRET=your_app_secret
INSTAGRAM_VERIFY_TOKEN=inboxpilot_verify_2024  # You choose this — any random string

# ── Shopify (AuraUp) ──
# Create a Custom App in auraupstore.myshopify.com → Settings → Apps → Develop apps
SHOPIFY_STORE_URL=auraupstore.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxx

# ── Klaviyo (optional for now) ──
KLAVIYO_API_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxx

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
# In production: https://inboxpilot.vercel.app or your custom domain
